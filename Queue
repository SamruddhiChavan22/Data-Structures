#include<iostream>
using namespace std;

#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

void insert() {
    int val;
    if(rear == MAX-1) {
        cout<<"Queue is Full (Overflow)";
    }
    else {
        cout<<"Enter value: ";
        cin>>val;
        if(front == -1)
            front = 0;
        rear++;
        queue[rear] = val;
        cout<<"Value inserted";
    }
}

void del() {
    if(front == -1 || front > rear) {
        cout<<"Queue is Empty (Underflow)";
    }
    else {
        cout<<"Deleted element = "<<queue[front];
        front++;
    }
}

void display() {
    if(front == -1 || front > rear) {
        cout<<"Queue is Empty";
    }
    else {
        cout<<"Queue elements are: ";
        for(int i=front;i<=rear;i++)
            cout<<queue[i]<<" ";
    }
}

int main() {
    int ch;

    do {
        cout<<"\n\n--- QUEUE MENU ---";
        cout<<"\n1. Insert";
        cout<<"\n2. Delete";
        cout<<"\n3. Display";
        cout<<"\n4. Exit";
        cout<<"\nEnter your choice: ";
        cin>>ch;

        switch(ch) {
            case 1: insert(); break;
            case 2: del(); break;
            case 3: display(); break;
            case 4: cout<<"Exiting..."; break;
            default: cout<<"Invalid choice";
        }

    } while(ch != 4);

    return 0;
}
